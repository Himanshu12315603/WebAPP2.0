# Server Configuration
PORT=5000
NODE_ENV=development
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/FUELFLUX
# MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.xxxxx.mongodb.net/FUELFLUX
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=3

# Security
JWT_SECRET=your_jwt_secret_here
COOKIE_SECRET=your_cookie_secret_here
JWT_EXPIRATION=24h

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Performance
STATIC_CACHE_DURATION=86400000
COMPRESSION_LEVEL=6

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
